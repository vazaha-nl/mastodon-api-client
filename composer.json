{
    "authors": [
        {
            "email": "lennart@vazaha.nl",
            "name": "Lennart Hengstmengel"
        }
    ],
    "autoload": {
        "psr-4": {
            "Vazaha\\Mastodon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Tools\\": "tools/src"
        }
    },
    "description": "A fully typed and feature complete Mastodon API client for PHP",
    "license": "MIT",
    "name": "vazaha-nl/mastodon-api-client",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.7",
        "illuminate/support": "^9 || ^10 || ^11 || ^12 || ^13",
        "nesbot/carbon": "^2.68 || ^3.0",
        "illuminate/collections": "^9 || ^10 || ^11 || ^12 || ^13"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1.22",
        "phpunit/phpunit": "^10 || ^11 || ^12",
        "squizlabs/php_codesniffer": "^3.7",
        "ergebnis/php-cs-fixer-config": "^5.12 || ^6.0",
        "twig/twig": "^3.7",
        "seld/cli-prompt": "^1.0",
        "vlucas/phpdotenv": "^5.6",
        "mirazmac/dotenvwriter": "^0.6.0",
        "erusev/parsedown": "^1.7",
        "friendsofphp/php-cs-fixer": "^3.80"
    },
    "scripts": {
        "check-style": [
            "php-cs-fixer fix --diff --dry-run"
        ],
        "fix-style": [
            "php-cs-fixer fix"
        ],
        "test": [
            "vendor/bin/phpunit --no-coverage --testsuite tests"
        ],
        "integration-test": [
            "vendor/bin/phpunit --no-coverage --testsuite integration_tests"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse -c phpstan.neon"
        ]
    },
    "type": "library",
    "config": {
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vazaha\\Mastodon\\ServiceProvider"
            ]
        }
    }
}
